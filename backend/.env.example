# -------------------------------------------------------
# Core Application
# -------------------------------------------------------
SECRET_KEY=replace_with_django_secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------------------
# Local JWT (legacy/internal API auth)
# -------------------------------------------------------
JWT_SECRET=replace_with_local_jwt_secret
JWT_EXPIRATION_HOURS=24
ADMIN_SIGNUP_CODE=

# -------------------------------------------------------
# Clerk Authentication
# -------------------------------------------------------
CLERK_AUTH_ENABLED=False
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_AUDIENCE=
CLERK_AUTO_CREATE_USERS=True
CLERK_DEFAULT_ROLE=user
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -------------------------------------------------------
# Database (PostgreSQL / PlanetScale)
# -------------------------------------------------------
# Option A: Full database URL (recommended)
# PostgreSQL example: postgresql://user:password@host:5432/database_name?sslmode=require
# PlanetScale MySQL example: mysql://user:password@host:3306/database_name
DATABASE_URL=

# Option B: Individual MySQL fields (used when USE_MYSQL=True)
USE_MYSQL=False
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306

# PlanetScale SSL options
DB_SSL_REQUIRED=False
DB_SSL_CA=

# -------------------------------------------------------
# File and Vector Storage
# -------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MEDIA_ROOT=media/
FAISS_INDEX_PATH=data/

# -------------------------------------------------------
# Runtime Controls
# -------------------------------------------------------
DISABLE_TRANSFORMER_MODEL=False
